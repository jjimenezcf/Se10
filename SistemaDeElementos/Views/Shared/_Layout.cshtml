        {
            <script src="/js/bundle.js" asp-append-version="true"></script>
        }
        else
        {
            <script src="~/js/_Literales/Literales.js" asp-append-version="true"></script>
            <script src="~/js/Mensajes.js" asp-append-version="true"></script>
