            <script src="~/js/_Api/ApiDeListasDinamicas.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDePeticiones.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDeMapeos.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDeExpansor.js" asp-append-version="true"></script>
