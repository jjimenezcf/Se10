            <script src="~/js/_TiposDeDatos/ModoAcceso.js" asp-append-version="true"></script>
            <script src="~/js/Utilidades.js" asp-append-version="true"></script>
            <script src="~/js/InfoSelector.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiLocalStorage.js" asp-append-version="true"></script>
            <script src="~/js/Registro.js" asp-append-version="true"></script>
            <script src="~/js/Cookies.js" asp-append-version="true"></script>
            <script src="~/js/HistorialDeNavegacion.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDeAjax.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDeAgenda.js" asp-append-version="true"></script>
