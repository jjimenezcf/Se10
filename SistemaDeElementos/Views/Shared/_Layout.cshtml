            <script src="~/js/_Api/MapearAlPanel.js" asp-append-version="true"></script>
            <script src="~/js/_Api/MapearAlControl.js" asp-append-version="true"></script>
            <script src="~/js/_Api/ApiDeDireccion.js" asp-append-version="true"></script>
            <script src="~/js/ArbolDeMenu.js" asp-append-version="true"></script>
            <script src="~/js/EntornoSe.js" asp-append-version="true"></script>
            <script src="~/js/_Formulario/FormularioBase.js" asp-append-version="true"></script>
            <script src="~/js/_Formulario/Jerarquia.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ApiDelCrud.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/CrudBase.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/GridDeDatos.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/CrudCreacion.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/CrudEdicion.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/CrudHistorial.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalConGrid.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalParaRelacionar.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalParaImputar.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalParaConsultarRelaciones.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalParaSeleccionar.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/ModalDeSeleccion.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/CrudMantenimiento.js" asp-append-version="true"></script>
            <script src="~/js/_Crud/GestorDeEventos.js" asp-append-version="true"></script>
        }
    }

    <script>
        @if (!accesoAnonimo)
        {
                @:EntornoSe.InicializarHistorial();
        }
    </script>
</head>

@using ServicioDeDatos

<body class="body-pagina">
    <div class="background-image"></div>
    @RenderBody()

    @if (!accesoAnonimo)
    {
        <script>
            document.documentElement.style.setProperty('--background-opacity', '@CacheDeVariable.LYT_Opacidad.ToString().Replace(",", ".")');
            document.documentElement.style.setProperty('--background-image-url', 'url("@CacheDeVariable.LYT_Imagen_De_Fondo")');
        </script>

        <div id="id-modal-menu" class="modal-menu">
            <div id="id-contenedor-menu" class="menu-contenedor">
            </div>
        </div>

        <div id="id-modal-historial" class="contenedor-modal-de-mensajes">
            <div id="id-contenedor-historial" class="contenido-modal">
                <div id="id-historial-cabecera" class="contenido-cabecera">
                    Historial de mensajes
                </div>
                <div id="id-historial-cuerpo" class="contenido-cuerpo" style="max-height: 30em;">
                    <div id="id-historial-cuerpo.tabla" class="div-tabla cuerpo-datos-tabla table table-striped" style="margin-bottom: 0px;">
                        <div id="id-historial-cuerpo.cabecera" class="div-thead thead-historial-mensajes">
                            <div id="id-historial-tabla.cabecera.fila" class="div-tr">
                                <div class="div-th columna-cabecera" propiedad="_mensaje" style="text-align: left; width: auto">
                                    Mensaje
                                </div>
                                <div class="div-th columna-cabecera" propiedad="_fecha" style="text-align: right; width: 5em">
                                    Fecha
                                </div>
                                <div class="div-th columna-cabecera" propiedad="_tipo" style="text-align: center; width: 5em">
                                    Tipo
                                </div>
                                <div class="div-th columna-cabecera" propiedad="_origen" style="text-align: left; width: 40em">
                                    Origen
                                </div>
                            </div>
                        </div>
                        <div id="id-historial-tabla.body" class="div-tbody cuerpo-datos-tbody">
                            <!-- lineas de la clase: cuerpo-datos-tbody-tr-->
                        </div>
                    </div>
                </div>
                <div id="{IdHtml}_pie" class="contenido-pie">
                    <input type="text" id="id-historial-cuerpo-cerrar" class="boton-modal" value="Cerrar" onclick="MensajesSe.CerrarHistorial()" readonly />
                    <input type="text" id="id-historial-cuerpo-borrar" class="boton-modal" value="Borrar" onclick="MensajesSe.BorrarHistorial()" readonly />
                </div>
            </div>
        </div>

        <div id="contenedor-subir-certificado">
        </div>

        <div id="contenedor-cambiar-password">
        </div>

        <div id="contenedor-modal-ia">
        </div>
    }
    @RenderSection("Scripts", required: false)

    @if (!accesoAnonimo)
    {
        <script>
            function Ajustar() {
            EntornoSe.AjustarDivs();
            }

            function Inicializar() {
            EntornoSe.IniciarEntorno();
            }

            function Navegar() {
            console.log("location: " + document.location + ", state: " + JSON.stringify(event.state));
            }

            window.onresize = Ajustar;
            window.onhashchange = Navegar;

            // document.addEventListener('DOMContentLoaded', function() {
            //     EntornoSe.IniciarEntorno();
            // });

            document.addEventListener('DOMContentLoaded', function() {
            @if (!accesoAnonimo)
            {
                    @:EntornoSe.IniciarEntorno();
            }
            });

        </script>
    }

</body>
</html>




